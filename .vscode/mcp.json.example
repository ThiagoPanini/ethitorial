{
  "servers": {
    "hostinger-vps": {
      "type": "stdio",
      "command": "node",
      "args": [
        "scripts/run-mcp-with-env.mjs",
        "HOSTINGER_API_TOKEN",
        "--",
        "npx",
        "-y",
        "--package",
        "hostinger-api-mcp@0.2.5",
        "hostinger-vps-mcp"
      ]
    },
    "coolify": {
      "type": "stdio",
      "command": "node",
      "args": [
        "scripts/run-mcp-with-env.mjs",
        "COOLIFY_ACCESS_TOKEN",
        "--",
        "npx",
        "-y",
        "@masonator/coolify-mcp@2.12.0"
      ],
      "env": {
        "COOLIFY_BASE_URL": "https://vps.thiagopanini.dev"
      }
    },
    "cloudflare": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    }
  }
}
