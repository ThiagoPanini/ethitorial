{
  "name": "epistemix",
  "private": true,
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:web": "pnpm --filter @epistemix/web dev",
    "build:web": "pnpm --filter @epistemix/web build",
    "typecheck:web": "pnpm --filter @epistemix/web typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0"
  }
}
