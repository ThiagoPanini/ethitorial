#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=_lib.sh
source "$SCRIPT_DIR/_lib.sh"

usage() {
  cat <<'USAGE'
Usage: block <issue#> "<reason>"

Moves board status to Blocked, sets Owner to Human, and comments what is
needed before the agent can continue.
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -ge 2 ]] || {
  usage >&2
  exit 2
}

require_tools
assert_project_scope_hint

issue=$1
shift
reason=$*
[[ -n "$reason" ]] || die "block reason is required"

status_field_name=$(status_field)
owner_field_name=$(owner_field)
me=$(current_user)
ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

set_single_select "$issue" "$status_field_name" "Blocked" >/dev/null
set_single_select "$issue" "$owner_field_name" "Human" >/dev/null

gh issue comment "$issue" --body "blocked @ $ts by @$me

Needs human input before continuing:

$reason" >/dev/null

status_after=$(get_single_select_value "$issue" "$status_field_name")
owner_after=$(get_single_select_value "$issue" "$owner_field_name")

[[ "$status_after" == "Blocked" ]] || die "block reread failed: $status_field_name=$status_after, expected Blocked"
[[ "$owner_after" == "Human" ]] || die "block reread failed: $owner_field_name=$owner_after, expected Human"

printf 'blocked #%s; %s=%s; %s=%s\n' "$issue" "$status_field_name" "$status_after" "$owner_field_name" "$owner_after"
